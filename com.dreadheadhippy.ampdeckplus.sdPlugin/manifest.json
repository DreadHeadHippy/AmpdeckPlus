      "States": [
        {
          "Image": "imgs/shuffle-icon",
          "ShowTitle": false
        }
      ],
      "SupportedInMultiActions": true,
      "Tooltip": "Toggle shuffle on/off",
      "UUID": "com.dreadheadhippy.ampdeckplus.shuffle",
      "PropertyInspectorPath": "pi.html"
    },
    {
      "Icon": "imgs/repeat-icon",
      "Name": "Repeat",
      "States": [
        {
          "Image": "imgs/repeat-default",
          "ShowTitle": false
        }
      ],
      "SupportedInMultiActions": true,
      "Tooltip": "Cycle repeat: Off → All → One",
      "UUID": "com.dreadheadhippy.ampdeckplus.repeat",
      "PropertyInspectorPath": "pi.html"
    },
    {
      "Icon": "imgs/track-title-icon",
      "Name": "Track Title",
      "States": [
        {
          "Image": "imgs/track-title-icon",
          "ShowTitle": false
        }
      ],
      "SupportedInMultiActions": false,
      "Tooltip": "Shows the current track title.",
      "UUID": "com.dreadheadhippy.ampdeckplus.track-title",
      "PropertyInspectorPath": "pi.html"
    },
    {
      "Icon": "imgs/volume-up-icon",
      "Name": "Volume Up",
      "States": [
        {
          "Image": "imgs/volume-up-icon",
          "ShowTitle": false
        }
      ],
      "SupportedInMultiActions": true,
      "Tooltip": "Increase volume by 5%",
      "UUID": "com.dreadheadhippy.ampdeckplus.volume-up",
      "PropertyInspectorPath": "pi.html"
    },
    {
      "Icon": "imgs/volume-down-icon",
      "Name": "Volume Down",
      "States": [
        {
          "Image": "imgs/volume-down-icon",
          "ShowTitle": false
        }
      ],
      "SupportedInMultiActions": true,
      "Tooltip": "Decrease volume by 5%",
      "UUID": "com.dreadheadhippy.ampdeckplus.volume-down",
      "PropertyInspectorPath": "pi.html"
    },
    {
      "Icon": "imgs/playlist-icon",
      "Name": "Play Playlist",
      "States": [
        {
          "Image": "imgs/playlist-icon",
          "ShowTitle": false
        }
      ],
      "SupportedInMultiActions": true,
      "Tooltip": "Press to start playing the configured Plex audio playlist",
      "UUID": "com.dreadheadhippy.ampdeckplus.playlist",
      "PropertyInspectorPath": "pi.html"
    }
  ],
  "UUID": "com.dreadheadhippy.ampdeckplus"
}